# Cloudflare Pages — HTTP headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/
# Patterns resolve top-to-bottom; more specific paths override general ones.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-PT3atvBjzRhSMOxOrZHDCgBrukSNFTz5d5TdpDuS+2Y=' https://static.cloudflareinsights.com; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloudflareinsights.com; form-action 'self' https://rustquantum-contact.aylaink.workers.dev; base-uri 'self'; frame-ancestors 'none'; upgrade-insecure-requests
  Cache-Control: public, max-age=300, must-revalidate

# Long-lived, content-hash filenames when versioning is introduced.
/assets/style.css
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

/assets/katex/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts must set CORS so they can be re-used across subdomains if needed.
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Images
/assets/favicon.svg
  Cache-Control: public, max-age=2592000

/assets/og-image.png
  Cache-Control: public, max-age=2592000

/assets/apple-touch-icon.png
  Cache-Control: public, max-age=2592000

/favicon.ico
  Cache-Control: public, max-age=2592000
